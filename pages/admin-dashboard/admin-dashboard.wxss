.page {
  min-height: 100vh;
  background: #f8fafc;
  padding-bottom: 40rpx;
}

/* 导航栏 */
.nav-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 60rpx 32rpx 24rpx;
  background: #ffffff;
  border-bottom: 1px solid #f1f5f9;
}

.nav-back {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.back-arrow {
  font-size: 44rpx;
  color: #1e293b;
  font-weight: bold;
}

.nav-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #1e293b;
}

.nav-placeholder {
  width: 64rpx;
}

/* 数据概览网格 */
.overview-grid {
  display: flex;
  flex-wrap: wrap;
  padding: 24rpx 24rpx 0;
  gap: 20rpx;
}

.overview-card {
  width: calc(50% - 10rpx);
  background: #ffffff;
  border-radius: 16rpx;
  padding: 28rpx 24rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.overview-num {
  font-size: 48rpx;
  font-weight: 700;
  color: #2563eb;
  margin-bottom: 8rpx;
}

.overview-label {
  font-size: 24rpx;
  color: #64748b;
}

/* Tab切换 */
.tab-section {
  margin: 24rpx 24rpx 0;
  background: #ffffff;
  border-radius: 16rpx;
  padding: 8rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.tab-list {
  display: flex;
}

.tab-item {
  flex: 1;
  text-align: center;
  padding: 20rpx 0;
  font-size: 28rpx;
  color: #64748b;
  border-radius: 12rpx;
  font-weight: 500;
}

.tab-item.active {
  background: #2563eb;
  color: #ffffff;
}

/* Section通用 */
.section {
  margin: 24rpx 24rpx 0;
  background: #ffffff;
  border-radius: 16rpx;
  padding: 28rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #1e293b;
}

.section-subtitle {
  font-size: 24rpx;
  color: #94a3b8;
}

/* 用户排名列表 */
.rank-list {
  width: 100%;
}

.rank-header {
  display: flex;
  align-items: center;
  padding: 16rpx 0;
  border-bottom: 2rpx solid #e2e8f0;
}

.rank-row {
  display: flex;
  align-items: center;
  padding: 24rpx 0;
  border-bottom: 1rpx solid #f1f5f9;
}

.rank-row:last-child {
  border-bottom: none;
}

.rank-row.top {
  background: linear-gradient(90deg, rgba(37, 99, 235, 0.05), transparent);
  margin: 0 -28rpx;
  padding-left: 28rpx;
  padding-right: 28rpx;
}

.rank-col {
  font-size: 26rpx;
  color: #334155;
}

.rank-num {
  width: 80rpx;
  text-align: center;
}

.rank-name {
  flex: 1.5;
  font-weight: 500;
}

.rank-school {
  flex: 2;
  color: #64748b;
  font-size: 24rpx;
}

.rank-time {
  width: 120rpx;
  text-align: right;
  font-weight: 600;
  color: #2563eb;
}

.rank-badge {
  display: inline-block;
  width: 44rpx;
  height: 44rpx;
  line-height: 44rpx;
  text-align: center;
  background: #f1f5f9;
  border-radius: 50%;
  font-size: 24rpx;
  color: #64748b;
  font-weight: 600;
}

.rank-badge.top-badge {
  background: linear-gradient(135deg, #fbbf24, #f59e0b);
  color: #ffffff;
}

.rank-header .rank-col {
  font-size: 22rpx;
  color: #94a3b8;
  font-weight: 600;
}

/* 院校列表 */
.school-list {
  width: 100%;
}

.school-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 0;
  border-bottom: 1rpx solid #f1f5f9;
}

.school-item:last-child {
  border-bottom: none;
}

.school-info {
  flex: 1;
}

.school-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #1e293b;
  display: block;
  margin-bottom: 8rpx;
}

.school-tags {
  display: flex;
  gap: 8rpx;
}

.school-tag {
  font-size: 20rpx;
  padding: 4rpx 12rpx;
  background: #eff6ff;
  color: #2563eb;
  border-radius: 4rpx;
}

.school-stats {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.school-users {
  font-size: 24rpx;
  color: #64748b;
}

.school-arrow {
  font-size: 28rpx;
  color: #cbd5e1;
}

/* 柱状图 */
.chart-container {
  padding: 20rpx 0;
}

.chart-bars {
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  height: 300rpx;
  padding: 0 10rpx;
}

.bar-group {
  display: flex;
  flex-direction: column;
  align-items: center;
  flex: 1;
  height: 100%;
  justify-content: flex-end;
}

.bar-bg {
  width: 40rpx;
  height: 240rpx;
  background: #f1f5f9;
  border-radius: 8rpx 8rpx 0 0;
  display: flex;
  flex-direction: column;
  justify-content: flex-end;
  overflow: hidden;
}

.bar-fill {
  width: 100%;
  background: linear-gradient(to top, #2563eb, #3b82f6);
  border-radius: 8rpx 8rpx 0 0;
  min-height: 4rpx;
  transition: height 0.3s ease;
}

.bar-label {
  font-size: 20rpx;
  color: #94a3b8;
  margin-top: 12rpx;
}

.bar-value {
  font-size: 20rpx;
  color: #2563eb;
  font-weight: 600;
  margin-bottom: 8rpx;
}

/* 退出管理按钮 */
.logout-wrap {
  padding: 40rpx 24rpx;
}

.logout-btn {
  width: 100%;
  height: 88rpx;
  background: #ffffff;
  color: #ef4444;
  font-size: 30rpx;
  font-weight: 600;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 2rpx solid #fecaca;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.bottom-space {
  height: 40rpx;
}
