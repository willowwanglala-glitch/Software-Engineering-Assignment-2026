.page {
  padding: 60rpx 40rpx;
  text-align: center;
}
.timer {
  background: #fff;
  border-radius: 50%;
  width: 480rpx;
  height: 480rpx;
  margin: 40rpx auto;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 40rpx rgba(74, 144, 217, 0.2);
}
.timer.running {
  border: 6rpx solid #4a90d9;
}
.time {
  font-size: 80rpx;
  font-weight: bold;
  color: #333;
  font-variant-numeric: tabular-nums;
}
.label {
  margin-top: 16rpx;
  color: #999;
  font-size: 28rpx;
}
.actions button {
  margin: 16rpx 0;
  border-radius: 12rpx;
  width: 80%;
}
.btn-start {
  background: #4a90d9 !important;
  color: #fff !important;
}
.btn-pause {
  background: #f5a623 !important;
  color: #fff !important;
}
.btn-stop {
  background: #fff !important;
  color: #e74c3c !important;
  border: 1px solid #e74c3c;
}
.hint {
  display: block;
  margin-top: 48rpx;
  color: #999;
  font-size: 24rpx;
}
