.page {
  min-height: 100vh;
  background: #f8fafc;
  display: flex;
  flex-direction: column;
  height: 100vh;
}

/* 导航栏 */
.nav-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 60rpx 30rpx 20rpx;
  background: #ffffff;
  border-bottom: 1px solid #f1f5f9;
  flex-shrink: 0;
}

.nav-back {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.back-icon {
  font-size: 40rpx;
  color: #1e293b;
  font-weight: bold;
}

.nav-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #1e293b;
}

.nav-placeholder {
  width: 60rpx;
}

/* 聊天列表 */
.chat-list {
  flex: 1;
  padding: 20rpx 30rpx;
  overflow-y: auto;
}

.message {
  margin-bottom: 24rpx;
}

.msg-row {
  display: flex;
  align-items: flex-start;
  gap: 16rpx;
}

.user-row {
  justify-content: flex-end;
}

/* 头像 */
.avatar {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.ai-avatar {
  background: #2563eb;
}

.avatar-text {
  font-size: 22rpx;
  color: #ffffff;
  font-weight: 700;
}

/* 气泡 */
.bubble {
  max-width: 70%;
  padding: 20rpx 24rpx;
  border-radius: 16rpx;
}

.ai-bubble {
  background: #ffffff;
  border: 1px solid #e2e8f0;
}

.user-bubble {
  background: #2563eb;
}

.bubble-text {
  font-size: 28rpx;
  color: #334155;
  line-height: 1.6;
}

.user-text {
  color: #ffffff;
}

/* 快捷建议 */
.suggestions {
  padding: 16rpx 30rpx;
  white-space: nowrap;
  flex-shrink: 0;
  background: #ffffff;
  border-top: 1px solid #f1f5f9;
}

.suggest-item {
  display: inline-block;
  background: #eff6ff;
  border: 1px solid #bfdbfe;
  border-radius: 24rpx;
  padding: 10rpx 24rpx;
  margin-right: 16rpx;
}

.suggest-text {
  font-size: 24rpx;
  color: #2563eb;
}

/* 输入框 */
.input-wrap {
  display: flex;
  align-items: center;
  padding: 16rpx 30rpx;
  padding-bottom: calc(16rpx + env(safe-area-inset-bottom));
  background: #ffffff;
  border-top: 1px solid #f1f5f9;
  gap: 16rpx;
  flex-shrink: 0;
}

.msg-input {
  flex: 1;
  background: #f1f5f9;
  border-radius: 24rpx;
  padding: 16rpx 24rpx;
  font-size: 28rpx;
  color: #334155;
}

.send-btn {
  background: #e2e8f0;
  border-radius: 24rpx;
  padding: 16rpx 32rpx;
}

.send-btn.active {
  background: #2563eb;
}

.send-text {
  font-size: 28rpx;
  color: #ffffff;
  font-weight: 600;
}