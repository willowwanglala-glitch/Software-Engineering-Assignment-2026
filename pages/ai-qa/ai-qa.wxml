<view class="page">
  <!-- 导航栏 -->
  <view class="nav-bar">
    <view class="nav-back" bindtap="goBack">
      <text class="back-icon">←</text>
    </view>
    <text class="nav-title">AI考研答疑助手</text>
    <view class="nav-placeholder"></view>
  </view>

  <!-- 聊天消息列表 -->
  <scroll-view class="chat-list" scroll-y scroll-into-view="{{scrollToId}}" scroll-with-animation>
    <view class="message {{item.role}}" wx:for="{{messages}}" wx:key="index" id="msg-{{index}}">
      <!-- AI消息 -->
      <view class="msg-row" wx:if="{{item.role === 'ai'}}">
        <view class="avatar ai-avatar">
          <text class="avatar-text">AI</text>
        </view>
        <view class="bubble ai-bubble">
          <text class="bubble-text">{{item.content}}</text>
        </view>
      </view>
      <!-- 用户消息 -->
      <view class="msg-row user-row" wx:else>
        <view class="bubble user-bubble">
          <text class="bubble-text user-text">{{item.content}}</text>
        </view>
      </view>
    </view>
    <view id="msg-bottom"></view>
  </scroll-view>

  <!-- 快捷建议 -->
  <scroll-view class="suggestions" scroll-x>
    <view class="suggest-item" wx:for="{{suggestions}}" wx:key="index" bindtap="sendSuggestion" data-text="{{item}}">
      <text class="suggest-text">{{item}}</text>
    </view>
  </scroll-view>

  <!-- 输入框 -->
  <view class="input-wrap">
    <input class="msg-input" placeholder="输入你的问题..." value="{{inputText}}" bindinput="onInput" bindconfirm="sendMessage" confirm-type="send" />
    <view class="send-btn {{inputText ? 'active' : ''}}" bindtap="sendMessage">
      <text class="send-text">发送</text>
    </view>
  </view>
</view>