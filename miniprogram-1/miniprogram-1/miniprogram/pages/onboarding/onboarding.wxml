<view class="page">
  <view class="steps">
    <text class="step-dot {{step >= 0 ? 'active' : ''}}">1 方向</text>
    <text class="step-line"></text>
    <text class="step-dot {{step >= 1 ? 'active' : ''}}">2 院校</text>
    <text class="step-line"></text>
    <text class="step-dot {{step >= 2 ? 'active' : ''}}">3 确认</text>
  </view>

  <!-- 步骤1：6 大考研方向 -->
  <block wx:if="{{step === 0}}">
    <view class="title">选择考研方向</view>
    <view class="dir-grid">
      <view
        wx:for="{{directions}}"
        wx:key="directionId"
        class="dir-card {{selectedDirectionId === item.directionId ? 'selected' : ''}}"
        data-id="{{item.directionId}}"
        data-name="{{item.directionName}}"
        bindtap="onSelectDirection"
      >
        <text class="dir-icon">{{item.icon}}</text>
        <text class="dir-name">{{item.directionName}}</text>
      </view>
    </view>
    <button class="btn-primary" bindtap="onNextToSchools">确认方向，查看院校</button>
  </block>

  <!-- 步骤2：15 所推荐院校 -->
  <block wx:if="{{step === 1}}">
    <view class="title">推荐院校（15所）</view>
    <text class="sub">已选方向：{{selectedDirectionName}}</text>
    <scroll-view scroll-y class="school-scroll">
      <view
        wx:for="{{universities}}"
        wx:key="_id"
        class="school-card"
        data-id="{{item._id}}"
        data-name="{{item.name}}"
        bindtap="onSelectUniversity"
      >
        <view class="school-head">
          <text class="school-name">{{item.name}}</text>
          <text class="school-region">{{item.region}}</text>
        </view>
        <view class="tag-row">
          <text wx:for="{{item.types}}" wx:key="*this" wx:for-item="t" class="tag tag-blue">{{t}}</text>
          <text wx:for="{{item.tags}}" wx:key="*this" wx:for-item="tg" class="tag">{{tg}}</text>
        </view>
      </view>
    </scroll-view>
    <button class="btn-ghost" bindtap="onBackStep">返回选择方向</button>
  </block>

  <!-- 步骤3：院校详情确认 -->
  <block wx:if="{{step === 2}}">
    <view class="title">确认备考画像</view>
    <view class="confirm-card" wx:if="{{detail}}">
      <text class="confirm-name">{{detail.name}}</text>
      <text class="confirm-meta">{{detail.region}} · {{selectedDirectionName}}</text>
      <text class="confirm-desc">{{detail.desc}}</text>
      <view class="tag-row">
        <text wx:for="{{detail.tags}}" wx:key="*this" class="tag">{{item}}</text>
      </view>
      <view class="books" wx:if="{{detail.books.length}}">
        <text class="books-label">参考书目</text>
        <text class="books-item" wx:for="{{detail.books}}" wx:key="*this">{{item}}</text>
      </view>
    </view>
    <view class="confirm-card" wx:else>
      <text class="confirm-name">{{selectedUniversityName}}</text>
      <text class="confirm-meta">{{selectedDirectionName}}</text>
    </view>
    <button class="btn-primary" bindtap="onSave">保存并进入首页</button>
    <button class="btn-ghost" bindtap="onBackStep">重新选择院校</button>
  </block>
</view>
