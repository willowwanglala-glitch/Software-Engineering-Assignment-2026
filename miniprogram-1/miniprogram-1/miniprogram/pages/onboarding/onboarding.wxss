.page {
  padding: 32rpx;
  padding-bottom: 48rpx;
  min-height: 100vh;
  box-sizing: border-box;
}
.steps {
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 40rpx;
}
.step-dot {
  font-size: 24rpx;
  color: #bbb;
}
.step-dot.active {
  color: #4a90d9;
  font-weight: bold;
}
.step-line {
  width: 48rpx;
  height: 2rpx;
  background: #e0e0e0;
  margin: 0 12rpx;
}
.title {
  font-size: 36rpx;
  font-weight: bold;
  margin-bottom: 24rpx;
  color: #333;
}
.sub {
  display: block;
  font-size: 26rpx;
  color: #666;
  margin-bottom: 24rpx;
}
.dir-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 20rpx;
  margin-bottom: 40rpx;
}
.dir-card {
  background: #fff;
  border: 2rpx solid transparent;
  border-radius: 16rpx;
  padding: 32rpx 20rpx;
  text-align: center;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.05);
}
.dir-card.selected {
  background: #4a90d9;
  border-color: #4a90d9;
}
.dir-card.selected .dir-name {
  color: #fff;
}
.dir-icon {
  display: block;
  font-size: 48rpx;
  margin-bottom: 12rpx;
}
.dir-name {
  font-size: 26rpx;
  font-weight: bold;
  color: #333;
  line-height: 1.4;
}
.school-scroll {
  max-height: 62vh;
  margin-bottom: 24rpx;
}
.school-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 28rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.05);
}
.school-head {
  display: flex;
  justify-content: space-between;
  align-items: baseline;
  margin-bottom: 12rpx;
}
.school-name {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
}
.school-region {
  font-size: 24rpx;
  color: #999;
}
.tag-row {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
}
.tag {
  font-size: 20rpx;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
  background: #f0f0f0;
  color: #666;
}
.tag-blue {
  background: #e8f2fc;
  color: #4a90d9;
}
.confirm-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 32rpx;
  margin-bottom: 32rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.05);
}
.confirm-name {
  display: block;
  font-size: 34rpx;
  font-weight: bold;
  color: #333;
}
.confirm-meta {
  display: block;
  margin-top: 8rpx;
  font-size: 26rpx;
  color: #666;
}
.confirm-desc {
  display: block;
  margin-top: 16rpx;
  font-size: 26rpx;
  color: #888;
  line-height: 1.5;
}
.books {
  margin-top: 24rpx;
  padding-top: 24rpx;
  border-top: 1rpx solid #eee;
}
.books-label {
  display: block;
  font-size: 24rpx;
  color: #999;
  margin-bottom: 8rpx;
}
.books-item {
  display: block;
  font-size: 26rpx;
  color: #555;
  margin-top: 6rpx;
}
.btn-primary {
  margin-top: 16rpx;
  background: #4a90d9 !important;
  color: #fff !important;
  border-radius: 12rpx;
}
.btn-ghost {
  margin-top: 16rpx;
  background: #fff !important;
  color: #4a90d9 !important;
  border: 1rpx solid #4a90d9 !important;
  border-radius: 12rpx;
}
