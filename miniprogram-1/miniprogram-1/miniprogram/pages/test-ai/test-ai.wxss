.page {
  padding: 32rpx;
  padding-bottom: 48rpx;
  min-height: 100vh;
  box-sizing: border-box;
  background: #f6f6f6;
}
.profile-bar {
  background: linear-gradient(135deg, #4a90d9, #6eb5ff);
  border-radius: 16rpx;
  padding: 28rpx 32rpx;
  color: #fff;
  margin-bottom: 28rpx;
}
.profile-bar.warn {
  background: linear-gradient(135deg, #e8a838, #f0c060);
}
.profile-label {
  display: block;
  font-size: 22rpx;
  opacity: 0.9;
}
.profile-value {
  display: block;
  margin-top: 8rpx;
  font-size: 30rpx;
  font-weight: bold;
}
.profile-link {
  display: block;
  margin-top: 12rpx;
  font-size: 24rpx;
  text-decoration: underline;
}
.quick-section {
  margin-bottom: 24rpx;
}
.section-title {
  display: block;
  font-size: 26rpx;
  color: #666;
  margin-bottom: 16rpx;
}
.quick-row {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}
.quick-chip {
  padding: 16rpx 28rpx;
  background: #fff;
  border-radius: 32rpx;
  font-size: 26rpx;
  color: #4a90d9;
  border: 1rpx solid #d0e4f7;
  box-shadow: 0 2rpx 8rpx rgba(74, 144, 217, 0.08);
}
.input-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.05);
}
.input-area {
  width: 100%;
  min-height: 160rpx;
  font-size: 28rpx;
  line-height: 1.5;
  color: #333;
}
.btn-row {
  display: flex;
  gap: 16rpx;
  margin-top: 20rpx;
}
.btn-send {
  flex: 1;
  background: #4a90d9 !important;
  color: #fff !important;
  border-radius: 12rpx;
  font-size: 28rpx;
}
.btn-clear {
  background: #f0f0f0 !important;
  color: #666 !important;
  border-radius: 12rpx;
  font-size: 26rpx;
  padding: 0 24rpx;
}
.answer-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 28rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.05);
}
.answer-title {
  display: block;
  font-size: 26rpx;
  font-weight: bold;
  color: #4a90d9;
  margin-bottom: 16rpx;
}
.answer-body {
  font-size: 28rpx;
  color: #333;
  line-height: 1.6;
  white-space: pre-wrap;
}
.footer-tip {
  display: block;
  text-align: center;
  margin-top: 32rpx;
  font-size: 22rpx;
  color: #bbb;
}
