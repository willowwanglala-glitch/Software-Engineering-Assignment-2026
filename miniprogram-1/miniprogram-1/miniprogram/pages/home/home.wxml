<view class="page">
  <view class="header">
    <text class="hello">你好，{{user.nickName || '同学'}}</text>
    <text class="profile" wx:if="{{user.targetSchool}}">{{user.direction}} · {{user.targetSchool}}</text>
    <text class="profile warn" wx:else bindtap="goOnboarding">点击完善备考画像 →</text>
  </view>

  <view class="stats-row">
    <view class="stat-card">
      <text class="num">{{stats.totalMinutes}}</text>
      <text class="unit">分钟</text>
      <text class="desc">近7日专注</text>
    </view>
    <view class="stat-card">
      <text class="num">{{stats.sessionCount}}</text>
      <text class="unit">次</text>
      <text class="desc">专注次数</text>
    </view>
  </view>

  <view class="menu">
    <navigator url="/pages/focus/focus" class="menu-item">
      <text class="menu-title">番茄专注</text>
      <text class="menu-tip">开始 25 分钟学习</text>
    </navigator>
    <navigator url="/pages/stats/stats" class="menu-item">
      <text class="menu-title">学习复盘</text>
      <text class="menu-tip">查看专注记录</text>
    </navigator>
    <navigator url="/pages/test-ai/test-ai" class="menu-item">
      <text class="menu-title">AI 答疑</text>
      <text class="menu-tip">考研英语智能问答</text>
    </navigator>
    <navigator url="/pages/onboarding/onboarding" class="menu-item">
      <text class="menu-title">院校与方向</text>
      <text class="menu-tip">6 大方向 · 15 所推荐院校</text>
    </navigator>
  </view>

  <text class="backend-tag">{{modeText}}</text>
</view>
