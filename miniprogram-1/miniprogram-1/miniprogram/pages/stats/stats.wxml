<view class="page">
  <view class="summary">
    <text class="title">近 7 日学习</text>
    <text class="big">{{stats.totalMinutes}} 分钟</text>
    <text class="sub">共 {{stats.sessionCount}} 次专注</text>
  </view>

  <view class="section-title">每日专注（分钟）</view>
  <view class="bar-list">
    <view class="bar-row" wx:for="{{chartList}}" wx:key="date">
      <text class="date">{{item.date}}</text>
      <view class="bar-bg">
        <view class="bar-fill" style="width: {{item.percent}}%"></view>
      </view>
      <text class="mins">{{item.minutes}}</text>
    </view>
    <view wx:if="{{!chartList.length}}" class="empty">暂无记录，去「专注」页开始番茄钟吧</view>
  </view>

  <view class="section-title">最近记录</view>
  <view class="log-item" wx:for="{{sessions}}" wx:key="_id">
    <text>{{item.date}} · {{item.subject}}</text>
    <text class="mins">{{item.durationMinutes}} 分钟</text>
  </view>
</view>
