.page {
  padding: 32rpx;
  padding-bottom: 120rpx;
}
.summary {
  background: linear-gradient(135deg, #4a90d9, #6eb5ff);
  color: #fff;
  border-radius: 20rpx;
  padding: 40rpx;
  margin-bottom: 32rpx;
}
.title {
  display: block;
  font-size: 28rpx;
  opacity: 0.9;
}
.big {
  display: block;
  font-size: 56rpx;
  font-weight: bold;
  margin: 16rpx 0;
}
.sub {
  font-size: 26rpx;
  opacity: 0.85;
}
.section-title {
  font-size: 30rpx;
  font-weight: bold;
  margin: 24rpx 0 16rpx;
  color: #333;
}
.bar-row {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
  font-size: 24rpx;
}
.date {
  width: 160rpx;
  color: #666;
}
.bar-bg {
  flex: 1;
  height: 20rpx;
  background: #eee;
  border-radius: 10rpx;
  overflow: hidden;
  margin: 0 16rpx;
}
.bar-fill {
  height: 100%;
  background: #4a90d9;
  border-radius: 10rpx;
  min-width: 4rpx;
}
.mins {
  width: 64rpx;
  text-align: right;
  color: #4a90d9;
}
.log-item {
  display: flex;
  justify-content: space-between;
  background: #fff;
  padding: 24rpx;
  border-radius: 12rpx;
  margin-bottom: 12rpx;
  font-size: 26rpx;
}
.empty {
  color: #999;
  font-size: 26rpx;
  padding: 24rpx 0;
}
