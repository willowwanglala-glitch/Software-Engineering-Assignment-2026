<view class="page">
  <view class="logo-area">
    <text class="app-name">Language for Life</text>
    <text class="sub">考研英语备考 · Alpha</text>
  </view>
  <view class="card">
    <text class="tip">使用微信登录后，可保存学习记录与 AI 答疑历史</text>
    <button class="btn-primary" bindtap="onLogin">微信一键登录</button>
    <button class="btn-ghost" bindtap="onLocalLogin">本地体验（无云开发）</button>
  </view>
  <text class="mode-tip">当前模式：{{modeText}}</text>
</view>
