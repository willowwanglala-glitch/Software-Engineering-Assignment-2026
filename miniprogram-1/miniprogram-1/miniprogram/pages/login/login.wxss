.page {
  min-height: 100vh;
  padding: 80rpx 40rpx;
  background: linear-gradient(180deg, #4a90d9 0%, #f6f6f6 45%);
}
.logo-area {
  text-align: center;
  margin-bottom: 60rpx;
  color: #fff;
}
.app-name {
  display: block;
  font-size: 48rpx;
  font-weight: bold;
}
.sub {
  display: block;
  margin-top: 16rpx;
  font-size: 26rpx;
  opacity: 0.9;
}
.card {
  background: #fff;
  border-radius: 24rpx;
  padding: 48rpx 40rpx;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.08);
}
.tip {
  display: block;
  color: #666;
  font-size: 26rpx;
  line-height: 1.6;
  margin-bottom: 40rpx;
}
.btn-primary {
  background: #4a90d9 !important;
  color: #fff !important;
  border-radius: 12rpx;
  margin-bottom: 24rpx;
}
.btn-ghost {
  color: #4a90d9 !important;
  border: 1px solid #4a90d9;
  border-radius: 12rpx;
  background: #fff !important;
}
.mode-tip {
  display: block;
  text-align: center;
  margin-top: 32rpx;
  color: #999;
  font-size: 24rpx;
}
