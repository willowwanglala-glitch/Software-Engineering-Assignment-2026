<view class="page">
  <!-- 导航栏 -->
  <view class="nav-bar">
    <view class="nav-back" bindtap="goBack">
      <text class="back-arrow">←</text>
    </view>
    <text class="nav-title">管理后台</text>
    <view class="nav-placeholder"></view>
  </view>

  <!-- 数据概览卡片 2x2 网格 -->
  <view class="overview-grid">
    <view class="overview-card">
      <text class="overview-num">{{overview.users}}</text>
      <text class="overview-label">注册用户数</text>
    </view>
    <view class="overview-card">
      <text class="overview-num">{{overview.active}}</text>
      <text class="overview-label">活跃用户数</text>
    </view>
    <view class="overview-card">
      <text class="overview-num">{{overview.study}}</text>
      <text class="overview-label">今日学习次数</text>
    </view>
    <view class="overview-card">
      <text class="overview-num">{{overview.ai}}</text>
      <text class="overview-label">AI答疑次数</text>
    </view>
  </view>

  <!-- Tab 切换 -->
  <view class="tab-section">
    <view class="tab-list">
      <view class="tab-item {{activeTab === 'users' ? 'active' : ''}}" bindtap="switchTab" data-tab="users">
        用户时长排名
      </view>
      <view class="tab-item {{activeTab === 'schools' ? 'active' : ''}}" bindtap="switchTab" data-tab="schools">
        院校列表
      </view>
    </view>
  </view>

  <!-- 用户时长排名 -->
  <view class="section" wx:if="{{activeTab === 'users'}}">
    <view class="section-header">
      <text class="section-title">用户使用时长排名</text>
      <text class="section-subtitle">按总学习时长排序</text>
    </view>
    <view class="rank-list">
      <view class="rank-header">
        <text class="rank-col rank-num">排名</text>
        <text class="rank-col rank-name">用户名</text>
        <text class="rank-col rank-school">目标院校</text>
        <text class="rank-col rank-time">总时长</text>
      </view>
      <view class="rank-row {{index < 3 ? 'top' : ''}}" wx:for="{{userRankList}}" wx:key="name">
        <view class="rank-col rank-num">
          <text class="rank-badge {{index < 3 ? 'top-badge' : ''}}">{{index + 1}}</text>
        </view>
        <text class="rank-col rank-name">{{item.name}}</text>
        <text class="rank-col rank-school">{{item.school}}</text>
        <text class="rank-col rank-time">{{item.totalTime}}h</text>
      </view>
    </view>
  </view>

  <!-- 院校列表 -->
  <view class="section" wx:if="{{activeTab === 'schools'}}">
    <view class="section-header">
      <text class="section-title">已有院校列表</text>
      <text class="section-subtitle">共 {{schoolList.length}} 所院校</text>
    </view>
    <view class="school-list">
      <view class="school-item" wx:for="{{schoolList}}" wx:key="name">
        <view class="school-info">
          <text class="school-name">{{item.name}}</text>
          <view class="school-tags">
            <text class="school-tag" wx:for="{{item.tags}}" wx:for-item="tag" wx:key="*this">{{tag}}</text>
          </view>
        </view>
        <view class="school-stats">
          <text class="school-users">{{item.userCount}}人选择</text>
          <text class="school-arrow">></text>
        </view>
      </view>
    </view>
  </view>

  <!-- 学习趋势柱状图 -->
  <view class="section">
    <text class="section-title">近7天学习趋势</text>
    <view class="chart-container">
      <view class="chart-bars">
        <view class="bar-group" wx:for="{{trendData}}" wx:key="label">
          <view class="bar-bg">
            <view class="bar-fill" style="height: {{item.percent}}%"></view>
          </view>
          <text class="bar-label">{{item.label}}</text>
          <text class="bar-value">{{item.value}}</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 退出管理按钮 -->
  <view class="logout-wrap">
    <view class="logout-btn" bindtap="logoutAdmin">退出管理</view>
  </view>

  <!-- 底部占位 -->
  <view class="bottom-space"></view>
</view>
