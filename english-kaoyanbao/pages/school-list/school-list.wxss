.page-container {
  min-height: 100vh;
  background: #f8fafc;
}

.nav-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 60rpx 32rpx 24rpx;
  background: #ffffff;
}

.nav-back {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.back-arrow {
  font-size: 40rpx;
  color: #1e293b;
  font-weight: bold;
}

.nav-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #1e293b;
}

.nav-placeholder {
  width: 64rpx;
}

.school-list {
  padding: 24rpx 32rpx;
}

.school-card {
  background: #ffffff;
  border-radius: 16rpx;
  padding: 28rpx;
  margin-bottom: 20rpx;
}

.school-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.school-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #1e293b;
  flex: 1;
}

.tag-group {
  display: flex;
  gap: 8rpx;
  flex-shrink: 0;
}

.tag {
  font-size: 22rpx;
  padding: 4rpx 12rpx;
  border-radius: 6rpx;
  font-weight: 500;
}

.tag-type {
  background: #dbeafe;
  color: #2563eb;
}

.school-info {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.city {
  font-size: 26rpx;
  color: #64748b;
}

.feature {
  font-size: 24rpx;
  color: #94a3b8;
  background: #f1f5f9;
  padding: 4rpx 12rpx;
  border-radius: 6rpx;
}
