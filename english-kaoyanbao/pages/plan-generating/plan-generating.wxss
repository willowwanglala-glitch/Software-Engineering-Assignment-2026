.page-container {
  min-height: 100vh;
  background: #ffffff;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 200rpx;
}

/* 加载动画 */
.loading-area {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 80rpx;
}

.spinner {
  width: 80rpx;
  height: 80rpx;
  border: 6rpx solid #e2e8f0;
  border-top: 6rpx solid #2563eb;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
  margin-bottom: 32rpx;
}

@keyframes spin {
  0% { transform: rotate(0deg); }
  100% { transform: rotate(360deg); }
}

.loading-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #1e293b;
}

/* 步骤列表 */
.steps-area {
  width: 100%;
  padding: 0 80rpx;
}

.step-item {
  display: flex;
  align-items: center;
  padding: 24rpx 0;
  opacity: 0.3;
  transition: opacity 0.3s;
}

.step-item.active {
  opacity: 1;
}

.step-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  background: #e2e8f0;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.step-item.active .step-dot {
  background: #2563eb;
}

.step-text {
  font-size: 28rpx;
  color: #475569;
}

.step-item.active .step-text {
  color: #1e293b;
  font-weight: 500;
}
