.page-container {
  min-height: 100vh;
  background: #f8fafc;
}

.nav-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 60rpx 32rpx 24rpx;
  background: #ffffff;
}

.nav-back {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.back-arrow {
  font-size: 40rpx;
  color: #1e293b;
  font-weight: bold;
}

.nav-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #1e293b;
}

.nav-placeholder {
  width: 64rpx;
}

.form-card {
  margin: 24rpx 32rpx;
  background: #ffffff;
  border-radius: 16rpx;
  padding: 28rpx;
}

.form-item {
  padding: 24rpx 0;
  border-bottom: 2rpx solid #f1f5f9;
}

.form-item:last-child {
  border-bottom: none;
}

.form-label {
  font-size: 28rpx;
  font-weight: 600;
  color: #1e293b;
  margin-bottom: 16rpx;
  display: block;
}

/* Picker */
.picker-value {
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 72rpx;
  background: #f8fafc;
  border-radius: 12rpx;
  padding: 0 24rpx;
}

.picker-text {
  font-size: 26rpx;
  color: #1e293b;
}

.picker-arrow {
  font-size: 28rpx;
  color: #94a3b8;
}

/* 数字输入 */
.number-input-area {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.num-btn {
  width: 64rpx;
  height: 64rpx;
  background: #f1f5f9;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  color: #475569;
  font-weight: 600;
}

.number-input {
  width: 120rpx;
  height: 64rpx;
  background: #f8fafc;
  border-radius: 12rpx;
  text-align: center;
  font-size: 28rpx;
  color: #1e293b;
  font-weight: 600;
}

.unit {
  font-size: 26rpx;
  color: #64748b;
}

/* 时长选项 */
.time-options {
  display: flex;
  gap: 16rpx;
}

.time-btn {
  flex: 1;
  height: 72rpx;
  background: #f8fafc;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 26rpx;
  color: #475569;
  font-weight: 500;
}

.time-btn.active {
  background: #2563eb;
  color: #ffffff;
}

/* 薄弱环节标签 */
.weakness-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.weakness-tag {
  padding: 16rpx 32rpx;
  background: #f1f5f9;
  border-radius: 32rpx;
  font-size: 26rpx;
  color: #475569;
  font-weight: 500;
  border: 2rpx solid transparent;
}

.weakness-tag.active {
  background: #dbeafe;
  color: #2563eb;
  border-color: #2563eb;
}

/* 生成按钮 */
.btn-area {
  padding: 40rpx 32rpx;
}

.generate-btn {
  width: 100%;
  height: 88rpx;
  background: linear-gradient(135deg, #2563eb, #1d4ed8);
  color: #ffffff;
  font-size: 30rpx;
  font-weight: 600;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
  line-height: 88rpx;
}

.generate-btn::after {
  border: none;
}
