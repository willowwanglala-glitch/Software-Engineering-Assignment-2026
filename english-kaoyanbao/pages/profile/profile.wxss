.page {
  min-height: 100vh;
  background: #f8fafc;
  padding-bottom: 120rpx;
}

/* 导航栏 */
.nav-bar {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 60rpx 30rpx 20rpx;
  background: #ffffff;
  border-bottom: 1px solid #f1f5f9;
}

.nav-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #1e293b;
}

/* 用户信息卡片 */
.user-card {
  display: flex;
  align-items: center;
  gap: 24rpx;
  background: #ffffff;
  margin: 24rpx 30rpx;
  border-radius: 16rpx;
  padding: 30rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.avatar {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  background: #2563eb;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.avatar-letter {
  font-size: 40rpx;
  font-weight: 700;
  color: #ffffff;
}

.user-info {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.user-name {
  font-size: 34rpx;
  font-weight: 700;
  color: #1e293b;
}

.user-school {
  font-size: 26rpx;
  color: #64748b;
}

/* 三列统计 */
.stats-row {
  display: flex;
  align-items: center;
  background: #ffffff;
  margin: 0 30rpx 24rpx;
  border-radius: 16rpx;
  padding: 30rpx 0;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.stat-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.stat-num {
  font-size: 36rpx;
  font-weight: 700;
  color: #2563eb;
}

.stat-label {
  font-size: 22rpx;
  color: #64748b;
  margin-top: 6rpx;
}

.stat-divider {
  width: 2rpx;
  height: 60rpx;
  background: #e2e8f0;
}

/* 管理后台卡片 */
.admin-card {
  background: linear-gradient(135deg, #2563eb, #1d4ed8);
  margin: 0 30rpx 24rpx;
  border-radius: 16rpx;
  padding: 30rpx;
  display: flex;
  align-items: center;
  position: relative;
}

.admin-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #ffffff;
}

.admin-desc {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
  margin-top: 6rpx;
  display: block;
}

.admin-arrow {
  font-size: 30rpx;
  color: rgba(255, 255, 255, 0.8);
  position: absolute;
  right: 30rpx;
  top: 50%;
  transform: translateY(-50%);
}

/* 菜单列表 */
.menu-list {
  background: #ffffff;
  margin: 0 30rpx 24rpx;
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.menu-item {
  display: flex;
  align-items: center;
  padding: 28rpx 30rpx;
  border-bottom: 1px solid #f1f5f9;
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-icon-text {
  font-size: 32rpx;
  color: #2563eb;
  margin-right: 20rpx;
  width: 40rpx;
  text-align: center;
}

.menu-name {
  flex: 1;
  font-size: 28rpx;
  color: #334155;
}

.menu-arrow {
  font-size: 28rpx;
  color: #94a3b8;
}

/* 退出登录 */
.logout-wrap {
  padding: 0 30rpx;
  margin-top: 20rpx;
}

.logout-btn {
  text-align: center;
  padding: 24rpx 0;
  border-radius: 12rpx;
  font-size: 30rpx;
  font-weight: 600;
  color: #ef4444;
  background: #ffffff;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

/* 底部占位 */
.bottom-placeholder {
  height: 100rpx;
}