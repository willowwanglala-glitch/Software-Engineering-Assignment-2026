.page-container {
  min-height: 100vh;
  background: #f8fafc;
  padding-bottom: 40rpx;
}

.nav-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 60rpx 32rpx 24rpx;
  background: #ffffff;
}

.nav-back {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.back-arrow {
  font-size: 40rpx;
  color: #1e293b;
  font-weight: bold;
}

.nav-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #1e293b;
  flex: 1;
  text-align: center;
  margin-right: 64rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.nav-placeholder {
  width: 64rpx;
}

.section {
  margin: 24rpx 32rpx 0;
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #1e293b;
  margin-bottom: 16rpx;
  display: block;
}

/* 概况卡片 */
.info-card {
  background: #ffffff;
  border-radius: 16rpx;
  padding: 28rpx;
}

.info-row {
  display: flex;
  align-items: center;
  padding: 16rpx 0;
  border-bottom: 2rpx solid #f1f5f9;
}

.info-row:last-of-type {
  border-bottom: none;
}

.info-label {
  font-size: 26rpx;
  color: #94a3b8;
  width: 160rpx;
  flex-shrink: 0;
}

.info-value {
  font-size: 26rpx;
  color: #1e293b;
  font-weight: 500;
}

.tag-group {
  display: flex;
  gap: 8rpx;
}

.tag {
  font-size: 22rpx;
  padding: 4rpx 16rpx;
  border-radius: 6rpx;
  background: #dbeafe;
  color: #2563eb;
  font-weight: 500;
}

.info-desc {
  margin-top: 16rpx;
}

.desc-text {
  font-size: 26rpx;
  color: #64748b;
  line-height: 1.8;
}

/* 参考书目 */
.book-scroll {
  width: 100%;
  white-space: nowrap;
}

.book-list {
  display: inline-flex;
  gap: 20rpx;
  padding: 8rpx 0;
}

.book-card {
  width: 200rpx;
  background: #ffffff;
  border-radius: 12rpx;
  padding: 20rpx;
  display: inline-flex;
  flex-direction: column;
  align-items: center;
}

.book-cover {
  width: 120rpx;
  height: 160rpx;
  background: linear-gradient(135deg, #2563eb, #3b82f6);
  border-radius: 8rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 12rpx;
}

.book-icon {
  font-size: 44rpx;
  color: #ffffff;
  font-weight: 600;
}

.book-name {
  font-size: 24rpx;
  color: #1e293b;
  font-weight: 500;
  text-align: center;
  white-space: normal;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
  margin-bottom: 8rpx;
}

.book-author {
  font-size: 22rpx;
  color: #94a3b8;
  white-space: normal;
}

/* 题型展示 */
.exam-card {
  background: #ffffff;
  border-radius: 16rpx;
  padding: 28rpx;
}

.exam-item {
  margin-bottom: 24rpx;
}

.exam-item:last-child {
  margin-bottom: 0;
}

.exam-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}

.exam-type {
  font-size: 28rpx;
  font-weight: 500;
  color: #1e293b;
}

.exam-score {
  font-size: 28rpx;
  font-weight: 700;
  color: #2563eb;
}

.exam-bar {
  width: 100%;
  height: 16rpx;
  background: #e2e8f0;
  border-radius: 8rpx;
  overflow: hidden;
}

.exam-fill {
  height: 100%;
  background: linear-gradient(135deg, #2563eb, #3b82f6);
  border-radius: 8rpx;
}

/* 院校特色 */
.feature-card {
  background: linear-gradient(135deg, #2563eb, #3b82f6);
  border-radius: 16rpx;
  padding: 28rpx;
}

.feature-text {
  font-size: 26rpx;
  color: #ffffff;
  line-height: 1.8;
}

/* 选择按钮 */
.btn-area {
  padding: 32rpx;
}

.select-btn {
  width: 100%;
  height: 88rpx;
  background: linear-gradient(135deg, #2563eb, #1d4ed8);
  color: #ffffff;
  font-size: 30rpx;
  font-weight: 600;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
  line-height: 88rpx;
}

.select-btn::after {
  border: none;
}
