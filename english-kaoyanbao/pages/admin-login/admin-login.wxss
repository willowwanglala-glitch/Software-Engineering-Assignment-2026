.page {
  min-height: 100vh;
  position: relative;
  overflow: hidden;
}

.bg {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: linear-gradient(135deg, #2563eb, #1d4ed8, #1e40af);
  z-index: 0;
}

.nav-back {
  position: relative;
  z-index: 1;
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 60rpx 0 0 32rpx;
}

.back-arrow {
  font-size: 40rpx;
  color: #ffffff;
  font-weight: bold;
}

.login-card {
  position: relative;
  z-index: 1;
  margin: 120rpx 60rpx 0;
  background: #ffffff;
  border-radius: 24rpx;
  padding: 60rpx 40rpx;
  box-shadow: 0 20rpx 60rpx rgba(0, 0, 0, 0.15);
}

.title {
  font-size: 40rpx;
  font-weight: 700;
  color: #1e293b;
  text-align: center;
  display: block;
  margin-bottom: 60rpx;
}

.input-group {
  margin-bottom: 32rpx;
}

.input-field {
  width: 100%;
  height: 88rpx;
  background: #f8fafc;
  border: 2rpx solid #e2e8f0;
  border-radius: 12rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
  color: #1e293b;
  box-sizing: border-box;
}

.input-field:focus {
  border-color: #2563eb;
  background: #eff6ff;
}

.login-btn {
  width: 100%;
  height: 88rpx;
  background: linear-gradient(135deg, #2563eb, #1d4ed8);
  color: #ffffff;
  font-size: 32rpx;
  font-weight: 600;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-top: 40rpx;
}
